{
  "name": "@voiceasset/site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && pnpm run build:static",
    "build:static": "astro build && node scripts/normalize-static-output.mjs",
    "check": "astro check",
    "check:contract": "node scripts/check-contract.mjs",
    "check:api-reference": "node scripts/generate-api-reference.mjs --check",
    "check:accessibility": "node scripts/check-accessibility.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:links": "node scripts/check-links.mjs",
    "generate:api-reference": "node scripts/generate-api-reference.mjs ../voice-asset-server/contracts/openapi.yaml",
    "licenses:check": "node scripts/check-licenses.mjs",
    "licenses:report": "node scripts/check-licenses.mjs --output third-party-licenses.json",
    "lint": "astro check",
    "test": "pnpm run check && pnpm run check:contract && pnpm run check:api-reference && pnpm run check:i18n && pnpm run build:static && pnpm run check:accessibility && pnpm run check:links && pnpm run licenses:check",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "0.41.3",
    "astro": "7.1.3",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3"
  }
}
